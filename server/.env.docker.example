# Docker 部署环境变量配置示例
# 复制此文件为 .env.docker 并修改配置

# PostgreSQL 配置
POSTGRES_DB=infopush
POSTGRES_USER=infopush
POSTGRES_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# JWT 密钥 (请生成随机字符串: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=CHANGE_ME_TO_RANDOM_SECRET_KEY

# 服务配置
HOST=0.0.0.0
PORT=8000